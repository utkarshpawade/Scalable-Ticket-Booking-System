# ============================================================
# Local development secrets — copy this file to `.env` and fill in.
# `.env` is gitignored. Never commit real secrets.
#
#   cp .env.example .env
#
# For PRODUCTION (Render / Vercel), set these as environment
# variables in each platform's dashboard — do NOT upload .env.
# ============================================================

# ---- Postgres ----
POSTGRES_USER=ticket
POSTGRES_PASSWORD=ticketpass
POSTGRES_DB=bookings

# ---- MongoDB ----
MONGO_USER=ticket
MONGO_PASSWORD=ticketpass
MONGO_DB=catalog

# ---- RabbitMQ ----
RABBITMQ_USER=ticket
RABBITMQ_PASSWORD=ticketpass

# ---- App secrets ----
# Generate a strong one with: openssl rand -base64 48
JWT_SECRET=change-me-in-prod
