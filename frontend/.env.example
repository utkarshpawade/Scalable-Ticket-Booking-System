# Frontend environment variables.
#
# LOCAL DEV: copy to `.env.local`, leave defaults — local dev hits the Nginx
# gateway at http://localhost:8080 (started by `docker compose up`).
#
# PRODUCTION (Vercel): set these in the Vercel project dashboard
# (Settings → Environment Variables) with your Render service URLs.

# Fallback used when NEXT_PUBLIC_*_URL vars below aren't set.
# Local dev points at the Nginx gateway. Leave commented in prod.
# NEXT_PUBLIC_API_BASE=http://localhost:8080/api

# Per-service URLs (production). Use the URL Render shows for each service.
# Example: https://user-service-abc123.onrender.com
NEXT_PUBLIC_USER_URL=
NEXT_PUBLIC_CATALOG_URL=
NEXT_PUBLIC_SEAT_URL=
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_RECO_URL=
